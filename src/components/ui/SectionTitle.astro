---
type Props = {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  reveal?: boolean;
};

const { eyebrow, title, subtitle, align = 'center', reveal = true } = Astro.props;
const alignment = align === 'center' ? 'text-center mx-auto' : 'text-left';
---

<header class:list={['mb-12 max-w-2xl', alignment]} data-reveal={reveal ? 'fade-up' : undefined}>
  {
    eyebrow && (
      <span class="inline-flex items-center gap-2 rounded-full bg-cheese-100 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-cheddar">
        <span class="h-1.5 w-1.5 rounded-full bg-cheddar" />
        {eyebrow}
      </span>
    )
  }
  <h2 class="mt-4 text-balance text-3xl font-extrabold text-espresso-900 sm:text-4xl md:text-5xl">
    {title}
  </h2>
  {
    subtitle && (
      <p class="mt-4 text-balance text-base leading-relaxed text-espresso-700 sm:text-lg">
        {subtitle}
      </p>
    )
  }
</header>
