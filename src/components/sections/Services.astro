---
import Container from '@/components/ui/Container.astro';
import SectionTitle from '@/components/ui/SectionTitle.astro';
import { SITE } from '@/lib/site';

const whatsappText = encodeURIComponent(
  'Hola Quesos La Colina, quiero hacer un pedido de productos lácteos.'
);
const whatsappUrl = `https://wa.me/${SITE.phoneRaw.replace('+', '')}?text=${whatsappText}`;
---

<section id="servicios" class="py-20 sm:py-28">
  <Container>
    <SectionTitle
      eyebrow="Nuestros servicios"
      title="De la fábrica a tu mesa, como prefieras"
      subtitle="Pedidos por WhatsApp, entregas a domicilio y atención a restaurantes y negocios. Tú eliges cómo recibir lo mejor de la sabana."
    />

    <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {[
        {
          icon: '🛒',
          title: 'Venta directa',
          description:
            'Haz tu pedido por WhatsApp y recibe productos frescos en la puerta de tu casa.',
        },
        {
          icon: '🏬',
          title: 'Distribución institucional',
          description:
            'Suministramos a restaurantes, casinos y negocios con logística y precios por volumen.',
        },
        {
          icon: '🧪',
          title: 'Calidad artesanal',
          description:
            'Procesos artesanales con leche local y controles de calidad en cada lote.',
        },
        {
          icon: '🚚',
          title: 'Domicilio gratis',
          description:
            'Entregas locales y envíos nacionales con embalajes especiales para lácteos.',
        },
      ].map((s, i) => (
        <li
          data-reveal="fade-up"
          style={`--reveal-delay: ${i * 80}ms`}
          class="group relative overflow-hidden rounded-3xl border border-espresso-900/5 bg-white p-6 shadow-card transition hover:-translate-y-1 hover:shadow-cheese"
        >
          <span
            aria-hidden="true"
            class="absolute -right-6 -top-6 grid h-24 w-24 place-items-center rounded-full bg-meadow-100 text-4xl transition group-hover:scale-110"
          >
            {s.icon}
          </span>
          <div class="relative pt-12">
            <span class="inline-block rounded-full bg-espresso-900 px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.18em] text-cheese-300">
              0{i + 1}
            </span>
            <h3 class="mt-3 font-display text-xl font-extrabold text-espresso-900">
              {s.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-espresso-700">
              {s.description}
            </p>
          </div>
        </li>
      ))}
    </ul>

    <div
      data-reveal="fade-up"
      class="mt-12 flex flex-col items-center gap-4 rounded-3xl bg-espresso-900 p-8 text-center text-cream-100 sm:p-10"
    >
      <p class="font-script text-3xl text-cheese-300">¿Listo para tu pedido?</p>
      <p class="max-w-xl text-sm text-cream-200/80">
        Recorre nuestro catálogo, agrega los productos que quieras y envíalo en
        un solo clic a nuestro WhatsApp. Te confirmamos disponibilidad, precio
        y entrega de inmediato.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-base"
      >
        <span aria-hidden="true">💬</span> Hablar con La Colina
      </a>
    </div>
  </Container>
</section>
