---
type Tone = 'cheddar' | 'cream' | 'espresso';

type Props = {
  label: string;
  icon?: 'star' | 'spark' | 'none';
  tone?: Tone;
  size?: 'sm' | 'md';
};

const { label, icon = 'none', tone = 'cheddar', size = 'sm' } = Astro.props;

const toneClasses: Record<Tone, string> = {
  cheddar: 'bg-cheddar text-espresso-900',
  cream: 'bg-cream-50 text-espresso-900 ring-1 ring-espresso-900/10',
  espresso: 'bg-espresso-900 text-cheese-300',
};

const sizeClasses: Record<'sm' | 'md', string> = {
  sm: 'px-2.5 py-1 text-[10px] gap-1',
  md: 'px-3 py-1.5 text-xs gap-1.5',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full font-bold uppercase tracking-[0.16em] shadow-card',
    toneClasses[tone],
    sizeClasses[size],
  ]}
>
  {icon === 'star' && (
    <svg
      aria-hidden="true"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="h-3 w-3"
    >
      <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 15l-5.3 2.8 1-5.9L1.5 7.7l5.9-.9L10 1.5z" />
    </svg>
  )}
  {icon === 'spark' && (
    <svg
      aria-hidden="true"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="h-3 w-3"
    >
      <path d="M10 2l1.6 4.4L16 8l-4.4 1.6L10 14l-1.6-4.4L4 8l4.4-1.6L10 2z" />
    </svg>
  )}
  <span>{label}</span>
</span>