---
import Container from '@/components/ui/Container.astro';
import { SITE } from '@/lib/site';

const year = new Date().getFullYear();

const sections = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Catálogo', href: '#productos' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Contacto', href: '#contacto' },
];

const social = [
  { name: 'Facebook', href: SITE.social.facebook, short: 'Fb' },
  { name: 'Instagram', href: SITE.social.instagram, short: 'Ig' },
];
---

<footer class="bg-espresso-900 text-cream-100">
  <Container class="py-16">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="flex items-center gap-3">
          <span class="grid h-16 w-16 place-items-center rounded-2xl bg-cream-50 ring-1 ring-cream-100/20 overflow-hidden">
            <img
              src={SITE.logoUrl}
              alt=""
              width="64"
              height="64"
              loading="eager"
              decoding="async"
              class="h-full w-full object-contain p-1"
            />
          </span>
          <span class="flex flex-col leading-none">
            <span class="font-script text-2xl text-cheese-300">La Colina</span>
            <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-cream-300/60">
              Quesos
            </span>
          </span>
        </div>
        <p class="mt-5 max-w-md text-sm leading-relaxed text-cream-200/80">
          Fábrica artesanal de quesos y yogures ubicada en Mosquera, Cundinamarca.
          Productos frescos del altiplano cundinamarqués con la tradición lechera
          de la sabana.
        </p>

        <ul class="mt-6 flex items-center gap-2" aria-label="Redes sociales">
          {social.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={s.name}
                class="grid h-10 w-10 place-items-center rounded-full bg-cream-100/10 text-sm font-bold text-cream-100 transition hover:bg-cheese-500 hover:text-espresso-900"
              >
                {s.short}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-[0.2em] text-cheese-300">
          Navegación
        </h3>
        <ul class="mt-4 space-y-2">
          {sections.map((s) => (
            <li>
              <a
                href={s.href}
                class="text-sm text-cream-200/80 transition hover:text-cheese-300"
              >
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-[0.2em] text-cheese-300">
          Contacto
        </h3>
        <ul class="mt-4 space-y-2 text-sm text-cream-200/80">
          <li>{SITE.address}</li>
          <li>
            <a href={`tel:${SITE.phoneRaw}`} class="transition hover:text-cheese-300">
              Cel. {SITE.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={`mailto:${SITE.email}`} class="transition hover:text-cheese-300">
              {SITE.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-cream-100/10 pt-6 text-xs text-cream-200/60 sm:flex-row sm:items-center">
      <p>© {year} {SITE.name}. Todos los derechos reservados.</p>
      <p class="font-script text-base text-cheese-300">¡Gracias por preferirnos!</p>
    </div>
  </Container>
</footer>
